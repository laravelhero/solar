---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import { company } from '../data/company';
const crumbs = [{ name: 'Home', href: '/' }, { name: 'Terms & Conditions', href: '/terms' }];
const updated = 'June 1, 2026';
const sections = [
  { h: 'Acceptance of Terms', p: ['By accessing or using this website, you agree to these Terms & Conditions. If you do not agree, please do not use the site.'] },
  { h: 'Use of the Website', p: ['You may use this website for lawful purposes only. You agree not to misuse the site, attempt unauthorized access, or interfere with its operation.'] },
  { h: 'Quotes & Estimates', p: ['Savings figures, calculator results and estimates on this site are illustrative and not guarantees. Your actual system, pricing, savings and incentives are confirmed only in a formal written proposal.'] },
  { h: 'Intellectual Property', p: ['All content on this site — text, graphics, logos and images — is the property of ' + company.legalName + ' or its licensors and is protected by applicable laws. You may not reproduce it without permission.'] },
  { h: 'Third-Party Links', p: ['Our site may link to third-party websites. We are not responsible for their content, policies or practices.'] },
  { h: 'Limitation of Liability', p: ['To the fullest extent permitted by law, ' + company.legalName + ' is not liable for any indirect, incidental or consequential damages arising from your use of this website.'] },
  { h: 'Changes to These Terms', p: ['We may update these terms from time to time. Continued use of the site after changes constitutes acceptance of the revised terms.'] },
  { h: 'Contact', p: [`Questions about these terms? Email ${company.email} or call ${company.phone}.`] },
];
---
<Layout title="Terms & Conditions" description={`Terms and conditions for using the ${company.name} website and services.`} canonical="/terms" robots="index, follow" breadcrumbs={crumbs}>
  <PageHero eyebrow="Legal" title="Terms & Conditions" subtitle={`Last updated: ${updated}`} crumbs={crumbs} />
  <section class="section">
    <div class="container-xl">
      <div class="prose-solar mx-auto max-w-3xl">
        {sections.map((s) => (
          <>
            <h2>{s.h}</h2>
            {s.p.map((para) => <p>{para}</p>)}
          </>
        ))}
      </div>
    </div>
  </section>
</Layout>
