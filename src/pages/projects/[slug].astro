---
import Layout from '../../layouts/Layout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import ProjectGrid from '../../components/ProjectGrid.astro';
import CTA from '../../components/CTA.astro';
import Icon from '../../components/Icon.astro';
import { projects } from '../../data/projects';
import { projectSchema } from '../../lib/schema';
import { formatDate } from '../../lib/blog';

export function getStaticPaths() {
  return projects.map((project) => ({ params: { slug: project.slug }, props: { project } }));
}
const { project } = Astro.props;
const related = projects.filter((p) => p.type === project.type && p.slug !== project.slug).slice(0, 3);
const crumbs = [
  { name: 'Home', href: '/' },
  { name: 'Projects', href: '/projects' },
  { name: project.name, href: `/projects/${project.slug}` },
];
const schemas = [projectSchema({ name: project.name, description: project.summary, url: `/projects/${project.slug}`, image: project.image, location: `${project.location}, ${project.state}` })];
---
<Layout
  title={project.seo.metaTitle}
  description={project.seo.metaDescription}
  keywords={project.seo.keywords}
  canonical={`/projects/${project.slug}`}
  image={project.image}
  breadcrumbs={crumbs}
  schemas={schemas}
>
  <!-- Hero image -->
  <section class="relative">
    <div class="relative aspect-[21/9] max-h-[60vh] w-full overflow-hidden bg-energy-950">
      <img src={project.image} alt={project.imageAlt} width="1920" height="820" fetchpriority="high" decoding="async" class="size-full object-cover" />
      <div class="absolute inset-0 bg-gradient-to-t from-energy-950 via-energy-950/40 to-transparent"></div>
      <div class="absolute inset-x-0 bottom-0">
        <div class="container-xl pb-8">
          <Breadcrumb crumbs={crumbs} light />
          <div class="mt-4 flex flex-wrap items-end justify-between gap-4">
            <div>
              <span class="rounded-full bg-solar-500 px-3 py-1 text-xs font-bold text-white">{project.type}</span>
              <h1 class="mt-3 max-w-3xl font-display text-3xl font-extrabold text-white text-balance sm:text-4xl lg:text-5xl">{project.name}</h1>
              <p class="mt-2 flex items-center gap-2 text-energy-100"><Icon name="map-pin" class="size-4 text-solar-300" /> {project.location}, {project.state} · Completed {formatDate(project.completion)}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Key metrics -->
  <section class="border-b border-gray-100 bg-white">
    <div class="container-xl grid grid-cols-2 gap-px py-2 sm:grid-cols-4">
      {[
        { label: 'System Size', value: project.systemSize, icon: 'sun' },
        { label: 'Panels', value: String(project.panels), icon: 'grid' },
        { label: 'Lifetime Savings', value: project.savings.split(' over')[0], icon: 'dollar' },
        { label: 'CO₂ Avoided', value: project.co2.split(' CO')[0], icon: 'leaf' },
      ].map((m) => (
        <div class="flex flex-col items-center gap-1 px-4 py-6 text-center">
          <Icon name={m.icon} class="size-6 text-solar-500" />
          <p class="font-display text-xl font-extrabold text-gray-900">{m.value}</p>
          <p class="text-xs font-medium text-gray-400">{m.label}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Case study body -->
  <section class="section">
    <div class="container-xl grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-8 space-y-10">
        <div>
          <h2 class="font-display text-2xl font-bold text-gray-900">Overview</h2>
          <p class="mt-3 text-lg leading-relaxed text-gray-600">{project.summary}</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          <div class="rounded-2xl bg-gray-50 p-6">
            <h3 class="flex items-center gap-2 font-display font-bold text-gray-900"><Icon name="search" class="size-5 text-solar-500" /> The Challenge</h3>
            <p class="mt-3 text-sm leading-relaxed text-gray-600">{project.challenge}</p>
          </div>
          <div class="rounded-2xl bg-grid-50 p-6 ring-1 ring-grid-100">
            <h3 class="flex items-center gap-2 font-display font-bold text-grid-900"><Icon name="bolt" class="size-5 text-grid-600" /> Our Solution</h3>
            <p class="mt-3 text-sm leading-relaxed text-grid-800">{project.solution}</p>
          </div>
        </div>

        <!-- Gallery -->
        <div>
          <h2 class="font-display text-2xl font-bold text-gray-900">Project gallery</h2>
          <div class="mt-5 grid grid-cols-2 gap-4 sm:grid-cols-3">
            {project.gallery.map((g) => (
              <div class="aspect-square overflow-hidden rounded-2xl bg-gray-100">
                <img src={g.src} alt={g.alt} width="400" height="400" loading="lazy" decoding="async" class="size-full object-cover transition-transform duration-500 hover:scale-105" />
              </div>
            ))}
          </div>
        </div>

        {project.testimonial && (
          <figure class="rounded-2xl bg-energy-950 p-8 text-white">
            <Icon name="quote" class="size-8 text-solar-400" />
            <blockquote class="mt-3 font-display text-xl font-medium leading-relaxed">{project.testimonial.quote}</blockquote>
            <figcaption class="mt-4 text-sm font-semibold text-energy-200">— {project.testimonial.author}</figcaption>
          </figure>
        )}
      </div>

      <!-- Results sidebar -->
      <aside class="lg:col-span-4">
        <div class="lg:sticky lg:top-28 space-y-6">
          <div class="card p-6">
            <h3 class="font-display text-lg font-bold text-gray-900">Results at a glance</h3>
            <dl class="mt-4 space-y-3">
              {project.results.map((r) => (
                <div class="flex items-center justify-between border-b border-gray-50 pb-3 last:border-0 last:pb-0">
                  <dt class="text-sm text-gray-500">{r.label}</dt>
                  <dd class="font-display font-bold text-solar-600">{r.value}</dd>
                </div>
              ))}
            </dl>
          </div>
          <div class="card bg-gradient-to-br from-solar-500 to-solar-600 p-6 text-white">
            <h3 class="font-display text-lg font-bold">Want results like these?</h3>
            <p class="mt-2 text-sm text-solar-50">Get a free, custom savings estimate for your home or business.</p>
            <a href="/quote" class="btn mt-4 w-full bg-white text-solar-700 hover:bg-solar-50">Get Free Quote</a>
          </div>
        </div>
      </aside>
    </div>
  </section>

  {related.length > 0 && (
    <section class="section bg-gray-50">
      <div class="container-xl">
        <SectionTitle eyebrow="More projects" title={`Similar ${project.type.toLowerCase()} installations`} class="mb-12" />
        <ProjectGrid projects={related} />
      </div>
    </section>
  )}

  <CTA />
</Layout>
