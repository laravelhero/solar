---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import Icon from '../components/Icon.astro';
import { company } from '../data/company';
import { socials } from '../data/socials';
import { localBusinessSchema } from '../lib/schema';

const crumbs = [{ name: 'Home', href: '/' }, { name: 'Contact', href: '/contact' }];
const contactCards = [
  { icon: 'phone', label: 'Call us', value: company.phone, href: company.phoneHref },
  { icon: 'mail', label: 'Email us', value: company.email, href: `mailto:${company.email}` },
  { icon: 'map-pin', label: 'Visit us', value: `${company.address.street}, ${company.address.city}, ${company.address.state}`, href: '#' },
  { icon: 'clock', label: 'Business hours', value: company.hours, href: '#' },
];
---
<Layout
  title="Contact Us"
  description="Get in touch with Apex Solar. Call, email or send us a message — our solar specialists typically respond within one business hour."
  keywords={['contact solar company', 'solar consultation', 'apex solar contact']}
  canonical="/contact"
  breadcrumbs={crumbs}
  schemas={[localBusinessSchema()]}
>
  <PageHero eyebrow="Get in Touch" title="We'd love to hear from you" subtitle="Questions about going solar? Ready for a quote? Our team is here to help — and we respond fast." crumbs={crumbs} />

  <section class="section">
    <div class="container-xl grid gap-12 lg:grid-cols-2">
      <div>
        <div class="grid gap-4 sm:grid-cols-2">
          {contactCards.map((c) => (
            <a href={c.href} class="card flex flex-col gap-3 p-6 transition-shadow hover:shadow-lg">
              <span class="grid size-11 place-items-center rounded-xl bg-solar-50 text-solar-600 ring-1 ring-solar-100"><Icon name={c.icon} class="size-5" /></span>
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-gray-400">{c.label}</p>
                <p class="mt-0.5 font-semibold text-gray-900">{c.value}</p>
              </div>
            </a>
          ))}
        </div>

        <div class="mt-6 card overflow-hidden">
          <div class="flex aspect-[16/10] items-center justify-center bg-gradient-to-br from-energy-100 to-solar-50">
            <div class="text-center">
              <Icon name="map-pin" class="mx-auto size-10 text-solar-500" />
              <p class="mt-2 font-display font-bold text-gray-900">{company.address.city}, {company.address.state}</p>
              <p class="text-sm text-gray-500">Serving 8 states nationwide</p>
            </div>
          </div>
        </div>

        <div class="mt-6 flex items-center gap-3">
          <span class="text-sm font-semibold text-gray-500">Follow us:</span>
          {socials.map((s) => (
            <a href={s.href} aria-label={s.name} target="_blank" rel="noopener" class="grid size-9 place-items-center rounded-full bg-gray-100 text-gray-600 hover:bg-solar-500 hover:text-white">
              <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true"><path d={s.icon} /></svg>
            </a>
          ))}
        </div>
      </div>

      <ContactForm variant="contact" />
    </div>
  </section>
</Layout>
