---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Stats from '../components/Stats.astro';
import TrustBadges from '../components/TrustBadges.astro';
import CTA from '../components/CTA.astro';
import Icon from '../components/Icon.astro';
import { company } from '../data/company';
import { stats } from '../data/stats';

const crumbs = [{ name: 'Home', href: '/' }, { name: 'About', href: '/about' }];
const values = [
  { icon: 'shield', title: 'Integrity First', text: 'Transparent, conservative estimates and no high-pressure sales — ever.' },
  { icon: 'award', title: 'Craftsmanship', text: 'In-house certified crews who treat every roof like their own.' },
  { icon: 'leaf', title: 'Real Impact', text: 'Measurable carbon reduction on every system we install.' },
  { icon: 'users', title: 'Customer Obsession', text: 'We earn the 5-star reviews one honest interaction at a time.' },
];
const timeline = [
  { year: '2009', title: 'Founded in Austin', text: 'Started as a two-person residential crew with a simple promise: do solar right.' },
  { year: '2014', title: 'Commercial division', text: 'Expanded into commercial and industrial solar across Texas.' },
  { year: '2019', title: 'Battery & storage', text: 'Added whole-home backup as storage technology came of age.' },
  { year: '2023', title: 'EV & 8-state footprint', text: 'Launched EV charging and grew to serve eight states nationwide.' },
  { year: '2026', title: '18,000+ systems', text: 'One of America’s most-trusted premium solar installers.' },
];
---
<Layout
  title="About Apex Solar — America's Premium Solar Installer"
  description={`Since ${company.foundedYear}, Apex Solar has installed 18,000+ solar systems across the USA. Learn about our mission, values and the team powering America's clean-energy future.`}
  keywords={['about apex solar', 'solar company', 'solar installer usa', 'solar mission']}
  canonical="/about"
  breadcrumbs={crumbs}
>
  <PageHero
    eyebrow="About Us"
    title="Powering America's clean-energy future since 2009"
    subtitle="We're on a mission to make premium solar simple, honest and accessible for every home and business in America."
    image="/images/team/about-team.jpg"
    imageAlt="The Apex Solar installation team in front of a completed project"
    crumbs={crumbs}
  />

  <section class="section">
    <div class="container-xl grid items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="eyebrow">Our Story</p>
        <h2 class="mt-4 font-display text-3xl font-bold text-gray-900">Solar done the right way</h2>
        <div class="mt-5 space-y-4 text-gray-600">
          <p>{company.name} was founded on a frustration: too many solar companies overpromised, underdelivered and disappeared. We set out to be the opposite — a premium installer that treats customers honestly and builds systems that last.</p>
          <p>Today, our in-house teams of NABCEP-certified engineers and installers have deployed over 412 megawatts of clean energy across eight states, saving our customers more than $94 million along the way.</p>
          <p>From a single rooftop in Austin to homes, warehouses, farms and factories nationwide, our standard has never changed: <strong class="text-gray-900">do solar right, every single time.</strong></p>
        </div>
        <div class="mt-8"><TrustBadges class="!justify-start" /></div>
      </div>
      <div class="grid gap-4">
        <img src="/images/team/about-install.jpg" alt="Apex Solar crew installing rooftop panels" width="640" height="420" loading="lazy" decoding="async" class="card aspect-[4/3] w-full object-cover" />
        <div class="grid grid-cols-2 gap-4">
          <img src="/images/team/about-engineer.jpg" alt="Solar engineer designing a system" width="320" height="320" loading="lazy" decoding="async" class="card aspect-square w-full object-cover" />
          <img src="/images/team/about-panels.jpg" alt="Close-up of premium solar panels" width="320" height="320" loading="lazy" decoding="async" class="card aspect-square w-full object-cover" />
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-gray-50">
    <div class="container-xl">
      <Stats stats={stats} />
    </div>
  </section>

  <section class="section">
    <div class="container-xl">
      <SectionTitle eyebrow="Our Values" title="What we stand for" subtitle="The principles behind every quote, every install and every service call." />
      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {values.map((v) => (
          <div class="card p-7">
            <span class="grid size-12 place-items-center rounded-2xl bg-solar-50 text-solar-600 ring-1 ring-solar-100"><Icon name={v.icon} class="size-6" /></span>
            <h3 class="mt-5 font-display text-lg font-bold text-gray-900">{v.title}</h3>
            <p class="mt-2 text-sm text-gray-500">{v.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-energy-950">
    <div class="container-xl">
      <SectionTitle light eyebrow="Our Journey" title="From a single rooftop to a national team" />
      <div class="mx-auto mt-14 max-w-3xl">
        {timeline.map((t, i) => (
          <div class="relative flex gap-6 pb-10 last:pb-0">
            {i < timeline.length - 1 && <div class="absolute left-[1.45rem] top-12 h-full w-px bg-white/15"></div>}
            <span class="z-10 grid size-12 shrink-0 place-items-center rounded-full bg-solar-500 font-display text-sm font-bold text-white">{t.year.slice(2)}</span>
            <div class="pt-1.5">
              <p class="font-display text-lg font-bold text-white">{t.title} <span class="text-solar-300">· {t.year}</span></p>
              <p class="mt-1 text-energy-200">{t.text}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</Layout>
