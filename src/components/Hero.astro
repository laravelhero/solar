---
import { company } from '../data/company';
import { impactStats } from '../data/stats';
import Icon from './Icon.astro';
---
<section class="relative overflow-hidden bg-energy-950">
  <!-- Background image + gradients -->
  <div class="absolute inset-0">
    <img src="/images/home/hero-solar-home.jpg" alt="Premium residential solar installation at golden hour" width="1920" height="1080" fetchpriority="high" decoding="async" class="size-full object-cover opacity-40" />
    <div class="absolute inset-0 bg-gradient-to-r from-energy-950 via-energy-950/85 to-energy-950/40"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-energy-950 via-transparent to-transparent"></div>
  </div>
  <div class="pointer-events-none absolute -right-32 top-10 size-96 rounded-full bg-solar-500/30 blur-3xl"></div>

  <div class="container-xl relative">
    <div class="grid items-center gap-12 py-20 lg:grid-cols-12 lg:py-28">
      <div class="lg:col-span-7" data-reveal>
        <p class="inline-flex items-center gap-2 rounded-full bg-white/10 px-3.5 py-1.5 text-xs font-semibold text-solar-200 ring-1 ring-white/15 backdrop-blur">
          <span class="flex items-center gap-1 text-solar-300"><Icon name="star" class="size-3.5 fill-solar-300" /> {company.ratings.value}★</span>
          <span class="h-3 w-px bg-white/20"></span>
          Trusted by {company.ratings.count.toLocaleString()}+ homes &amp; businesses
        </p>

        <h1 class="mt-6 font-display text-4xl font-extrabold leading-[1.05] tracking-tight text-white text-balance sm:text-5xl lg:text-6xl">
          Power your home with <span class="gradient-text">clean solar energy</span> &amp; cut your bill to zero
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-energy-100 text-pretty">
          Premium residential, commercial &amp; industrial solar, battery storage and EV charging — engineered, installed and serviced by America's most trusted solar team.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a href="/quote" class="btn-primary px-8 py-4 text-base">Get a Free Quote <Icon name="arrow-right" class="size-4" /></a>
          <a href="#calculator" class="btn bg-white/10 px-8 py-4 text-base text-white ring-1 ring-white/20 backdrop-blur hover:bg-white/20">
            <Icon name="calculator" class="size-4" /> Calculate My Savings
          </a>
        </div>

        <ul class="mt-8 flex flex-wrap gap-x-6 gap-y-2">
          {['$0 Down Financing', '30% Tax Credit', '25-Year Warranty'].map((b) => (
            <li class="flex items-center gap-2 text-sm font-medium text-energy-100">
              <Icon name="check-circle" class="size-5 text-grid-400" /> {b}
            </li>
          ))}
        </ul>
      </div>

      <!-- Floating glass stat card -->
      <div class="lg:col-span-5" data-reveal style="animation-delay:150ms">
        <div class="glass mx-auto max-w-sm rounded-3xl p-7 lg:ml-auto">
          <p class="text-sm font-semibold text-gray-500">Real impact, measured</p>
          <dl class="mt-4 grid grid-cols-2 gap-5">
            {impactStats.map((s) => (
              <div>
                <dt class="font-display text-2xl font-extrabold text-gray-900">{s.value}</dt>
                <dd class="mt-0.5 text-xs font-medium text-gray-500">{s.label}</dd>
              </div>
            ))}
          </dl>
          <div class="mt-6 flex items-center gap-3 rounded-2xl bg-grid-50 p-4 ring-1 ring-grid-100">
            <Icon name="leaf" class="size-8 shrink-0 text-grid-600" />
            <p class="text-sm font-medium text-grid-800">Every install offsets ~28 tons of CO₂ — like planting 460 trees.</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Wave divider -->
  <div class="relative">
    <svg viewBox="0 0 1440 60" class="block w-full text-white" preserveAspectRatio="none" aria-hidden="true">
      <path fill="currentColor" d="M0 60V20c240 30 480 30 720 0s480-30 720 0v40H0Z" />
    </svg>
  </div>
</section>
