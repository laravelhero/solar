---
import { locations } from '../data/locations';
import Icon from './Icon.astro';
---
<div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
  {locations.map((l, i) => (
    <a href={`/locations/${l.slug}`} class="group card overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-xl" data-reveal style={`animation-delay:${i * 50}ms`}>
      <div class="relative aspect-[3/2] overflow-hidden bg-gray-100">
        <img src={l.image} alt={l.imageAlt} width="400" height="267" loading="lazy" decoding="async" class="size-full object-cover transition-transform duration-500 group-hover:scale-105" />
        <div class="absolute inset-0 bg-gradient-to-t from-energy-950/80 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-4">
          <p class="flex items-center gap-1.5 font-display text-lg font-bold text-white">
            <Icon name="map-pin" class="size-4 text-solar-400" /> {l.state}
          </p>
          <p class="text-xs text-energy-100">{l.cities.slice(0, 3).join(' · ')}</p>
        </div>
      </div>
      <div class="flex items-center justify-between p-4">
        <span class="text-sm font-semibold text-grid-600">Save ~{l.avgSavings}</span>
        <Icon name="arrow-right" class="size-4 text-solar-500 transition-transform group-hover:translate-x-1" />
      </div>
    </a>
  ))}
</div>
