---
// Services mega-menu panel. Rendered inside the desktop nav and shown via the
// Alpine `open` state owned by Header.astro. 5 columns + featured CTA card.
import { megaMenu, megaMenuFeatured } from '../data/navigation';
import Icon from './Icon.astro';
---
<div
  x-show="open"
  x-cloak
  x-transition:enter="transition ease-out duration-200"
  x-transition:enter-start="opacity-0 -translate-y-2"
  x-transition:enter-end="opacity-100 translate-y-0"
  x-transition:leave="transition ease-in duration-150"
  x-transition:leave-start="opacity-100 translate-y-0"
  x-transition:leave-end="opacity-0 -translate-y-2"
  @mouseenter="open = true"
  @mouseleave="open = false"
  class="absolute inset-x-0 top-full z-40 hidden lg:block"
>
  <div class="container-xl pt-3">
    <div class="overflow-hidden rounded-3xl bg-white shadow-2xl ring-1 ring-gray-900/5">
      <div class="grid grid-cols-12">
        <!-- 5 service columns -->
        <div class="col-span-9 grid grid-cols-5 gap-x-6 gap-y-2 p-7">
          {megaMenu.map((col) => (
            <div>
              <div class="mb-3 flex items-center gap-2">
                <span class="grid size-8 place-items-center rounded-lg bg-solar-50 text-solar-600">
                  <Icon name={col.icon} class="size-4.5" />
                </span>
                <div>
                  <p class="text-sm font-bold text-gray-900">{col.label}</p>
                </div>
              </div>
              <ul class="space-y-0.5">
                {col.links.map((link) => (
                  <li>
                    <a
                      href={link.href}
                      class="group block rounded-lg px-2 py-1.5 transition-colors hover:bg-solar-50"
                    >
                      <span class="block text-sm font-medium text-gray-700 group-hover:text-solar-700">{link.label}</span>
                      <span class="block text-xs text-gray-400">{link.description}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>

        <!-- Featured CTA -->
        <div class="col-span-3 relative flex flex-col justify-between gap-4 bg-gradient-to-br from-energy-800 to-energy-950 p-7 text-white">
          <div>
            <p class="eyebrow !bg-white/10 !text-solar-200 !ring-white/10">{megaMenuFeatured.eyebrow}</p>
            <h3 class="mt-3 font-display text-xl font-bold leading-snug">{megaMenuFeatured.title}</h3>
            <p class="mt-2 text-sm text-energy-100">{megaMenuFeatured.description}</p>
          </div>
          <div class="space-y-3">
            <a href={megaMenuFeatured.cta.href} class="btn-primary w-full">
              {megaMenuFeatured.cta.label}
              <Icon name="arrow-right" class="size-4" />
            </a>
            <a href="/services" class="block text-center text-sm font-semibold text-energy-100 hover:text-white">
              View all services →
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
