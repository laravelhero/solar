---
import { company } from '../data/company';
import { socials } from '../data/socials';
import { footerNav } from '../data/navigation';
import { locations } from '../data/locations';
import Logo from './Logo.astro';
import Icon from './Icon.astro';
const year = new Date().getFullYear();
---
<footer class="bg-energy-950 text-energy-100">
  <!-- CTA strip -->
  <div class="container-xl">
    <div class="relative -mb-px overflow-hidden rounded-3xl bg-gradient-to-r from-solar-500 to-solar-600 px-6 py-10 sm:px-12 sm:py-12" style="margin-top:-3.5rem">
      <div class="relative z-10 flex flex-col items-center justify-between gap-6 text-center sm:flex-row sm:text-left">
        <div>
          <h2 class="font-display text-2xl font-bold text-white sm:text-3xl">Ready to power your future with the sun?</h2>
          <p class="mt-2 max-w-xl text-solar-50">Get a free, no-obligation quote and see your 25-year savings in about 60 seconds.</p>
        </div>
        <div class="flex shrink-0 flex-col gap-3 sm:flex-row">
          <a href="/quote" class="btn bg-white text-solar-700 hover:bg-solar-50">Get Free Quote</a>
          <a href={company.phoneHref} class="btn bg-energy-950/30 text-white ring-1 ring-white/30 hover:bg-energy-950/50">
            <Icon name="phone" class="size-4" /> Call Now
          </a>
        </div>
      </div>
      <div class="pointer-events-none absolute -right-12 -top-12 size-48 rounded-full bg-white/10 blur-2xl"></div>
    </div>
  </div>

  <div class="container-xl pb-10 pt-20">
    <div class="grid grid-cols-2 gap-8 lg:grid-cols-6">
      <!-- Brand -->
      <div class="col-span-2">
        <Logo variant="light" />
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-energy-200">{company.description}</p>
        <div class="mt-5 space-y-2 text-sm">
          <a href={company.phoneHref} class="flex items-center gap-2 hover:text-white"><Icon name="phone" class="size-4 text-solar-400" /> {company.phone}</a>
          <a href={`mailto:${company.email}`} class="flex items-center gap-2 hover:text-white"><Icon name="mail" class="size-4 text-solar-400" /> {company.email}</a>
          <p class="flex items-start gap-2"><Icon name="map-pin" class="mt-0.5 size-4 shrink-0 text-solar-400" /> {company.address.street}, {company.address.city}, {company.address.state} {company.address.zip}</p>
        </div>
        <div class="mt-5 flex items-center gap-3">
          {socials.map((s) => (
            <a href={s.href} aria-label={s.name} target="_blank" rel="noopener" class="grid size-9 place-items-center rounded-full bg-white/5 text-energy-200 transition-colors hover:bg-solar-500 hover:text-white">
              <svg viewBox="0 0 24 24" class="size-4" fill="currentColor" aria-hidden="true"><path d={s.icon} /></svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Link columns -->
      {footerNav.map((col) => (
        <div>
          <h3 class="text-sm font-bold uppercase tracking-wider text-white">{col.heading}</h3>
          <ul class="mt-4 space-y-2.5">
            {col.links.map((link) => (
              <li><a href={link.href} class="text-sm text-energy-200 transition-colors hover:text-solar-300">{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Service areas -->
    <div class="mt-12 border-t border-white/10 pt-8">
      <p class="text-xs font-bold uppercase tracking-wider text-energy-300">Proudly serving</p>
      <div class="mt-3 flex flex-wrap gap-x-4 gap-y-2">
        {locations.map((l) => (
          <a href={`/locations/${l.slug}`} class="text-sm text-energy-200 hover:text-solar-300">{l.state}</a>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-6 text-xs text-energy-300 sm:flex-row">
      <p>© {year} {company.legalName}. All rights reserved. · {company.license}</p>
      <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-1">
        <a href="/privacy-policy" class="hover:text-white">Privacy Policy</a>
        <a href="/terms" class="hover:text-white">Terms &amp; Conditions</a>
        <a href="/sitemap" class="hover:text-white">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
