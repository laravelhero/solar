---
// Slide-in mobile navigation with accordion service categories.
import { mainNav, megaMenu } from '../data/navigation';
import { company } from '../data/company';
import Icon from './Icon.astro';
import Logo from './Logo.astro';
---
<div
  x-show="$store.ui.mobileMenu"
  x-cloak
  class="fixed inset-0 z-[60] lg:hidden"
  @keydown.escape.window="$store.ui.closeMobile()"
>
  <!-- Backdrop -->
  <div
    x-show="$store.ui.mobileMenu"
    x-transition:enter="transition-opacity ease-out duration-300"
    x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100"
    x-transition:leave="transition-opacity ease-in duration-200"
    x-transition:leave-start="opacity-100" x-transition:leave-end="opacity-0"
    class="absolute inset-0 bg-gray-900/50 backdrop-blur-sm"
    @click="$store.ui.closeMobile()"
  ></div>

  <!-- Panel -->
  <div
    x-show="$store.ui.mobileMenu"
    x-transition:enter="transition ease-out duration-300"
    x-transition:enter-start="translate-x-full" x-transition:enter-end="translate-x-0"
    x-transition:leave="transition ease-in duration-200"
    x-transition:leave-start="translate-x-0" x-transition:leave-end="translate-x-full"
    class="absolute inset-y-0 right-0 flex w-[88%] max-w-sm flex-col bg-white shadow-2xl"
    x-data="{ openCat: null }"
  >
    <div class="flex items-center justify-between border-b border-gray-100 px-5 py-4">
      <Logo />
      <button type="button" @click="$store.ui.closeMobile()" class="grid size-10 place-items-center rounded-full text-gray-500 hover:bg-gray-100" aria-label="Close menu">
        <svg viewBox="0 0 24 24" class="size-6" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18" /></svg>
      </button>
    </div>

    <nav class="flex-1 overflow-y-auto px-3 py-4" aria-label="Mobile">
      <ul class="space-y-1">
        {mainNav.filter((l) => l.label !== 'Services').slice(0, 2).map((link) => (
          <li>
            <a href={link.href} class="block rounded-xl px-3 py-3 text-base font-semibold text-gray-900 hover:bg-solar-50">{link.label}</a>
          </li>
        ))}

        <!-- Services accordion -->
        <li class="pt-1">
          <p class="px-3 pb-1 text-xs font-bold uppercase tracking-wider text-gray-400">Services</p>
          {megaMenu.map((cat, i) => (
            <div class="border-b border-gray-50 last:border-0">
              <button
                type="button"
                class="flex w-full items-center justify-between rounded-lg px-3 py-3 text-left"
                @click={`openCat = openCat === ${i} ? null : ${i}`}
                :aria-expanded={`openCat === ${i}`}
              >
                <span class="flex items-center gap-2.5 text-sm font-semibold text-gray-900">
                  <span class="grid size-7 place-items-center rounded-lg bg-solar-50 text-solar-600"><Icon name={cat.icon} class="size-4" /></span>
                  {cat.label}
                </span>
                <Icon name="chevron-down" class="size-4 text-gray-400 transition-transform" x-bind:class={`openCat === ${i} && 'rotate-180'`} />
              </button>
              <ul x-show={`openCat === ${i}`} x-cloak class="space-y-0.5 pb-2 pl-12">
                {cat.links.map((link) => (
                  <li><a href={link.href} class="block rounded-lg px-3 py-2 text-sm text-gray-600 hover:bg-solar-50 hover:text-solar-700">{link.label}</a></li>
                ))}
              </ul>
            </div>
          ))}
        </li>

        {mainNav.filter((l) => !['Home', 'About', 'Services'].includes(l.label)).map((link) => (
          <li>
            <a href={link.href} class="block rounded-xl px-3 py-3 text-base font-semibold text-gray-900 hover:bg-solar-50">{link.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="space-y-3 border-t border-gray-100 p-5">
      <a href="/quote" class="btn-primary w-full">Get Free Quote</a>
      <a href={company.phoneHref} class="btn-ghost w-full">
        <Icon name="phone" class="size-4" /> {company.phone}
      </a>
    </div>
  </div>
</div>
