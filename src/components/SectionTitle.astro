---
interface Props {
  eyebrow?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  light?: boolean;
  class?: string;
}
const { eyebrow, title, subtitle, align = 'center', light = false, class: className = '' } = Astro.props;
const wrap = align === 'center' ? 'mx-auto max-w-3xl text-center' : 'max-w-2xl';
---
<div class={`${wrap} ${className}`} data-reveal>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class={`mt-4 font-display text-3xl font-bold tracking-tight text-balance sm:text-4xl lg:text-[2.75rem] lg:leading-[1.1] ${light ? 'text-white' : 'text-gray-900'}`}>
    <Fragment set:html={title} />
  </h2>
  {subtitle && <p class={`mt-4 text-lg leading-relaxed text-pretty ${light ? 'text-energy-100' : 'text-gray-500'}`}>{subtitle}</p>}
</div>
