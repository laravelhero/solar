---
import { company } from '../data/company';
interface Props { class?: string; variant?: 'dark' | 'light' }
const { class: className = '', variant = 'dark' } = Astro.props;
const text = variant === 'light' ? 'text-white' : 'text-gray-900';
---
<a href="/" class={`group inline-flex items-center gap-2.5 ${className}`} aria-label={`${company.name} home`}>
  <span class="relative grid size-10 place-items-center rounded-xl bg-gradient-to-br from-solar-500 to-solar-600 shadow-[var(--shadow-glow)] transition-transform duration-300 group-hover:scale-105">
    <svg viewBox="0 0 24 24" class="size-6 text-white" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="4" fill="currentColor" stroke="none" />
      <path d="M12 2.5v2.5M12 19v2.5M21.5 12H19M5 12H2.5M18.7 5.3l-1.8 1.8M7.1 16.9l-1.8 1.8M18.7 18.7l-1.8-1.8M7.1 7.1 5.3 5.3" />
    </svg>
  </span>
  <span class={`font-display text-xl font-bold tracking-tight ${text}`}>
    Apex<span class="text-solar-500">Solar</span>
  </span>
</a>
